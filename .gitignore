# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# envs
ds_env
icu_dev

# MIMIC Data files (STRICT EXCLUSION: Do not commit PHI or large sets)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model Checkpoints (Exclude files >100MB handled by PyTorch Lightning)
models/*
!models/.gitkeep
*.ckpt
*.pt
*.pth

# Notebook outputs (stripped by nbstripout, but ignore checkpoints)
.ipynb_checkpoints
notebooks/.ipynb_checkpoints

# MLOps Logs
wandb/
mlruns/
lightning_logs/

# OS generated files
.DS_Store
Thumbs.db